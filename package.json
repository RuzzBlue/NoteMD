{
  "name": "notemd",
  "version": "3.0.1",
  "private": true,
  "description": "Electron note taking app with markdown + TinyMCE",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "set NODE_ENV=development&& electron .",
    "pack": "electron-builder --dir",
    "prepare:win-cache": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-win-build-cache.ps1",
    "dist": "npm run prepare:win-cache && set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "marked": "^15.0.12",
    "rtf-parser": "^1.3.3",
    "tinymce": "^8.7.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "electron": "^42.5.2",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.notemd.app",
    "productName": "NoteMD",
    "forceCodeSigning": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "icon": "build/icon.png",
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NoteMD"
    }
  }
}
